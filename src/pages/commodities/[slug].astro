---
import Layout from '../../layouts/Layout.astro';
import CtaBand from '../../components/CtaBand.astro';
import { commodities } from '../../data/commodities';

export function getStaticPaths() {
  return commodities.map((c) => ({ params: { slug: c.slug }, props: { commodity: c } }));
}

const { commodity: c } = Astro.props;
const others = commodities.filter((o) => o.slug !== c.slug).slice(0, 4);
---

<Layout title={c.seoTitle} description={c.seoDescription}>
  <article class="mx-auto max-w-4xl px-4 pt-12">
    <nav aria-label="Breadcrumb" class="text-sm text-ink/60">
      <a href="/" class="hover:underline">Home</a> ›
      <a href="/commodities/" class="hover:underline">Commodities</a> ›
      <span>{c.name}</span>
    </nav>

    <div class="mt-4 flex items-start gap-4">
      <span class="text-5xl" aria-hidden="true">{c.emoji}</span>
      <div>
        <h1 class="font-display text-3xl font-semibold leading-tight text-forest-800 sm:text-4xl">
          {c.h1}
        </h1>
        <p class="mt-1 text-lg text-forest-500">{c.kannada}</p>
      </div>
    </div>

    {c.intro.map((p) => <p class="mt-5 text-lg leading-relaxed text-ink/85">{p}</p>)}

    <h2 class="mt-10 font-display text-2xl font-semibold text-forest-700">
      {c.name} Varieties & Grades We Handle
    </h2>
    <ul class="mt-4 space-y-2">
      {
        c.varieties.map((v) => (
          <li class="flex gap-3 leading-relaxed text-ink/85">
            <span class="mt-1 text-forest-600" aria-hidden="true">
              ●
            </span>
            {v}
          </li>
        ))
      }
    </ul>

    <div class="mt-10 grid gap-6 sm:grid-cols-2">
      <div class="rounded-2xl border border-forest-600/10 bg-cream-50 p-6">
        <h2 class="font-display text-xl font-semibold text-forest-700">
          If You Want to Buy {c.name}
        </h2>
        <ul class="mt-3 space-y-2 text-sm leading-relaxed text-ink/80">
          {
            c.forBuyers.map((b) => (
              <li class="flex gap-2">
                <span class="text-forest-600" aria-hidden="true">
                  ✓
                </span>
                {b}
              </li>
            ))
          }
        </ul>
        <a
          href={`/contact/?side=Buy&commodity=${encodeURIComponent(c.name)}`}
          class="mt-4 inline-block rounded-full bg-forest-600 px-5 py-2.5 text-sm font-semibold text-cream-50 transition hover:bg-forest-700"
          >Post a buying requirement</a
        >
      </div>
      <div class="rounded-2xl border border-forest-600/10 bg-cream-50 p-6">
        <h2 class="font-display text-xl font-semibold text-forest-700">
          If You Want to Sell {c.name}
        </h2>
        <ul class="mt-3 space-y-2 text-sm leading-relaxed text-ink/80">
          {
            c.forSellers.map((s) => (
              <li class="flex gap-2">
                <span class="text-forest-600" aria-hidden="true">
                  ✓
                </span>
                {s}
              </li>
            ))
          }
        </ul>
        <a
          href={`/contact/?side=Sell&commodity=${encodeURIComponent(c.name)}`}
          class="mt-4 inline-block rounded-full bg-forest-600 px-5 py-2.5 text-sm font-semibold text-cream-50 transition hover:bg-forest-700"
          >Post a selling requirement</a
        >
      </div>
    </div>

    <p class="mt-8 rounded-2xl bg-forest-100/60 p-6 text-lg leading-relaxed text-forest-800">
      {c.closing}
    </p>

    <h2 class="mt-12 font-display text-xl font-semibold text-forest-700">Other Commodities</h2>
    <ul class="mt-3 flex flex-wrap gap-2">
      {
        others.map((o) => (
          <li>
            <a
              href={`/commodities/${o.slug}/`}
              class="inline-block rounded-full border border-forest-600/20 bg-cream-50 px-4 py-1.5 text-sm font-medium text-forest-700 transition hover:border-forest-600/50"
            >
              {o.emoji} {o.name}
            </a>
          </li>
        ))
      }
    </ul>
  </article>

  <CtaBand
    heading={`Trade ${c.name.toLowerCase()} with us`}
    sub="Post your requirement — commodity, quantity and expected price — and we will call you back."
  />
</Layout>
