---
import Layout from '../layouts/Layout.astro';
import CtaBand from '../components/CtaBand.astro';
import { SITE, WHATSAPP_LINK } from '../config';

const title = 'How Our Commodity Brokerage Works — Buyers & Sellers | Subbaraju Brokerage';
const description =
  'How Subbaraju Brokerage works for buyers and sellers of agri commodities in Karnataka: post your requirement, we match and negotiate, goods move, payment is settled.';

const buyerSteps = [
  {
    t: 'Tell us what you need',
    d: 'Post your requirement on this website or WhatsApp us: commodity, quality/grade, quantity, delivery location and your target price.',
  },
  {
    t: 'We source and quote',
    d: 'We check availability with mills, traders and farmers in our network and come back with a realistic landed rate — usually the same day.',
  },
  {
    t: 'Approve the quality',
    d: 'For new buyers we work sample-first wherever possible. You approve the sample or lot description before anything is dispatched.',
  },
  {
    t: 'Dispatch and delivery',
    d: 'We coordinate weighment, loading and transport. You receive exactly the quantity and grade that was agreed.',
  },
  {
    t: 'Settle and repeat',
    d: 'Payment terms are fixed before the deal. Most of our buyers come back every season — that is the business model.',
  },
];

const sellerSteps = [
  {
    t: 'Tell us what you have',
    d: 'Post your lot details: commodity, variety, approximate quality (moisture, grade), quantity and your expected price.',
  },
  {
    t: 'We find genuine buyers',
    d: 'We match your lot with verified buyers — wholesalers, mills, feed plants or out-of-state distributors — and negotiate on your behalf.',
  },
  {
    t: 'Rate is fixed transparently',
    d: 'You get a clear rate pegged to the current market. No hidden deductions surface later — everything is agreed up front.',
  },
  {
    t: 'Quick lifting',
    d: 'Once the deal is fixed, we arrange lorries and lifting quickly so you avoid storage losses and free up your space.',
  },
  {
    t: 'Payment follow-up',
    d: 'We stay on the deal until your payment is settled as agreed. That follow-up is a core part of what you engage a broker for.',
  },
];
---

<Layout title={title} description={description}>
  <section class="mx-auto max-w-6xl px-4 pt-12">
    <nav aria-label="Breadcrumb" class="text-sm text-ink/60">
      <a href="/" class="hover:underline">Home</a> › <span>How It Works</span>
    </nav>
    <h1 class="mt-4 font-display text-4xl font-semibold text-forest-800">How It Works</h1>
    <p class="mt-4 max-w-3xl text-lg leading-relaxed text-ink/80">
      A commodity broker earns their fee by removing risk from the trade: finding genuine
      counterparties, fixing honest rates, and staying on the deal until goods and money have both
      moved. Here is exactly what working with {SITE.name} looks like — whether you are buying or
      selling.
    </p>

    <div class="mt-12 grid gap-10 lg:grid-cols-2">
      <!-- Buyer flow -->
      <div>
        <h2 class="font-display text-2xl font-semibold text-forest-700">
          🛒 If You Are a Buyer
        </h2>
        <p class="mt-2 text-ink/70">
          Retailers, distributors, wholesalers, feed mills and processors.
        </p>
        <ol class="mt-6 space-y-5">
          {
            buyerSteps.map((s, i) => (
              <li class="flex gap-4">
                <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-forest-600 font-display font-bold text-cream-50">
                  {i + 1}
                </span>
                <div>
                  <h3 class="font-display text-lg font-semibold text-forest-700">{s.t}</h3>
                  <p class="mt-1 leading-relaxed text-ink/80">{s.d}</p>
                </div>
              </li>
            ))
          }
        </ol>
      </div>

      <!-- Seller flow -->
      <div>
        <h2 class="font-display text-2xl font-semibold text-forest-700">
          🌾 If You Are a Seller
        </h2>
        <p class="mt-2 text-ink/70">Farmers, millers, manufacturers and processing units.</p>
        <ol class="mt-6 space-y-5">
          {
            sellerSteps.map((s, i) => (
              <li class="flex gap-4">
                <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-forest-600 font-display font-bold text-cream-50">
                  {i + 1}
                </span>
                <div>
                  <h3 class="font-display text-lg font-semibold text-forest-700">{s.t}</h3>
                  <p class="mt-1 leading-relaxed text-ink/80">{s.d}</p>
                </div>
              </li>
            ))
          }
        </ol>
      </div>
    </div>

    <div class="mt-12 rounded-2xl border border-forest-600/10 bg-cream-50 p-6">
      <h2 class="font-display text-xl font-semibold text-forest-700">A note on brokerage</h2>
      <p class="mt-2 leading-relaxed text-ink/80">
        Our brokerage is a standard market commission agreed openly before the deal — there are no
        hidden margins built into the rate. Both sides know exactly what the price is and what the
        brokerage is. If you have questions, call us at
        <a href={`tel:${SITE.phoneRaw}`} class="font-semibold text-forest-600 underline underline-offset-4">{SITE.phoneDisplay}</a>
        or
        <a href={WHATSAPP_LINK} target="_blank" rel="noopener" class="font-semibold text-forest-600 underline underline-offset-4">message us on WhatsApp</a>.
      </p>
    </div>
  </section>

  <CtaBand />
</Layout>
