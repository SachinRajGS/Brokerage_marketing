---
import Layout from '../../layouts/Layout.astro';
import CtaBand from '../../components/CtaBand.astro';
import { commodities } from '../../data/commodities';

const title = 'Agri Commodities We Broker | Rice, Groundnut, Maize & More | Subbaraju Brokerage';
const description =
  'Commodities brokered by Subbaraju Brokerage, Challakere: rice, groundnut, maize, toor dal, gram, gram dal, gram flour, fried gram, peas, husk, cashew cake and ragi. Serving Karnataka, Andhra Pradesh and Tamil Nadu.';
---

<Layout title={title} description={description}>
  <section class="mx-auto max-w-6xl px-4 pt-12">
    <nav aria-label="Breadcrumb" class="text-sm text-ink/60">
      <a href="/" class="hover:underline">Home</a> › <span>Commodities</span>
    </nav>
    <h1 class="mt-4 font-display text-4xl font-semibold text-forest-800">
      Agricultural Commodities We Broker
    </h1>
    <p class="mt-4 max-w-3xl text-lg leading-relaxed text-ink/80">
      From our base in Challakere, Karnataka, we broker the region’s major agricultural
      commodities between growers, mills and manufacturers on one side and wholesalers,
      distributors and retailers on the other. Select a commodity below to see varieties,
      grades and how we work with buyers and sellers.
    </p>

    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        commodities.map((c) => (
          <a
            href={`/commodities/${c.slug}/`}
            class="group flex flex-col rounded-2xl border border-forest-600/10 bg-cream-50 p-6 transition hover:-translate-y-0.5 hover:border-forest-600/30 hover:shadow-md"
          >
            <span class="text-4xl" aria-hidden="true">
              {c.emoji}
            </span>
            <h2 class="mt-3 font-display text-xl font-semibold text-forest-700 group-hover:underline">
              {c.name} <span class="text-base font-normal text-forest-500">· {c.kannada}</span>
            </h2>
            <p class="mt-2 flex-1 leading-relaxed text-ink/75">{c.card}</p>
            <span class="mt-4 text-sm font-semibold text-forest-600">
              View {c.name.toLowerCase()} details →
            </span>
          </a>
        ))
      }
    </div>

    <div class="mt-12 rounded-2xl border border-forest-600/10 bg-cream-50 p-6">
      <h2 class="font-display text-xl font-semibold text-forest-700">
        Don’t see your commodity listed?
      </h2>
      <p class="mt-2 leading-relaxed text-ink/80">
        We also handle other agricultural commodities traded around Challakere and central
        Karnataka on request — including onion, sunflower and seasonal pulses.
        <a href="/contact/" class="font-semibold text-forest-600 underline underline-offset-4">
          Post your requirement</a
        > and we will tell you honestly whether we can help.
      </p>
    </div>
  </section>

  <CtaBand />
</Layout>
