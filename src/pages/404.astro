---
import Layout from '../layouts/Layout.astro';

const title = 'Page Not Found | Subbaraju Brokerage';
const description = 'The page you were looking for does not exist. Browse our commodities or post your requirement.';
---

<Layout title={title} description={description}>
  <section class="mx-auto max-w-3xl px-4 py-24 text-center">
    <p class="font-display text-6xl font-bold text-forest-300">404</p>
    <h1 class="mt-4 font-display text-3xl font-semibold text-forest-800">Page not found</h1>
    <p class="mt-3 text-lg text-ink/75">
      That page doesn’t exist — but the market is still open.
    </p>
    <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
      <a href="/" class="rounded-full bg-forest-600 px-6 py-3 font-semibold text-cream-50 transition hover:bg-forest-700">Go home</a>
      <a href="/commodities/" class="rounded-full border-2 border-forest-600 px-6 py-3 font-semibold text-forest-700 transition hover:bg-forest-50">Browse commodities</a>
    </div>
  </section>
</Layout>
